<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_rounded"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical">

    <FrameLayout
        android:id="@+id/widget_avatar_container"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginEnd="16dp"
        android:padding="5dp">

        <ImageView
            android:id="@+id/widget_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_big_heart" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TA正在：息屏休息 💤"
            android:textColor="#334155"
            android:textSize="15sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_tv_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_widget_tag_green"
                android:textColor="#2E7D32"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="🔋 85%"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/widget_tv_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_widget_tag_blue"
                android:textColor="#1565C0"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="📍 幸福小区"
                android:singleLine="true"
                android:ellipsize="end"
                android:textStyle="bold"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_tv_weather"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_widget_tag_orange"
            android:textColor="#E65100"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="☀️ 晴 25°C · 适合穿短袖出街"
               android:textSize="12sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
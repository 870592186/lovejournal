<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:paddingHorizontal="16dp"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/log_tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12:30:45"
        android:textColor="#888888"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/log_tv_type"
        android:layout_width="36dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:gravity="center"
        android:text="GPS"
        android:textColor="#2196F3"
        android:textSize="10sp"
        android:textStyle="bold"
        android:background="@drawable/bg_log_tag_light"
        app:layout_constraintBottom_toBottomOf="@id/log_tv_time"
        app:layout_constraintStart_toEndOf="@id/log_tv_time"
        app:layout_constraintTop_toTopOf="@id/log_tv_time" />

    <TextView
        android:id="@+id/log_tv_latlng"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="39.9123, 116.4123"
        android:textColor="#444444"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="@id/log_tv_time"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/log_tv_time" />

    <TextView
        android:id="@+id/log_tv_address"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="上海市浦东新区陆家嘴世纪大道1号"
        android:textColor="#666666"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/log_tv_time" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="8dp"
        android:background="#EEEEEE"
        app:layout_constraintTop_toBottomOf="@id/log_tv_address" />

</androidx.constraintlayout.widget.ConstraintLayout>